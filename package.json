{
  "name": "research-memo-builder",
  "version": "0.1.0",
  "private": true,
  "description": "Reserch memo builder for note articles.",
  "homepage": "https://github.com/KJ-LEATHER-GAMES/research-memo-builder#readme",
  "bugs": {
    "url": "https://github.com/KJ-LEATHER-GAMES/research-memo-builder/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KJ-LEATHER-GAMES/research-memo-builder.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "research": "tsx src/cli/research.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"research/**/*.yaml\" \"docs/**/*.md\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"research/**/*.yaml\" \"docs/**/*.md\" \"*.json\"",
    "check": "npm run typecheck && npm run format:check"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "keywords": []
}
